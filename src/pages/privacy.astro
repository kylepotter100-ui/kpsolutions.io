---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { breadcrumbSchema, type JsonLdSchema } from "../lib/schema";
import { ORG_EMAIL } from "../lib/site";
import "../styles/legal.css";

const SITE = "https://kpsolutions.io";
const title = "Privacy — KP Solutions";
const description =
  "How KP Solutions handles the information you share through the contact form. No analytics, no cookies, no tracking — only what you choose to send.";

const schemas: JsonLdSchema[] = [
  breadcrumbSchema([
    { name: "Home", url: `${SITE}/` },
    { name: "Privacy", url: `${SITE}/privacy` },
  ]),
];

const updated = "June 2026";
---

<BaseLayout title={title} description={description} schemas={schemas}>
  <Header heroMode="light" />
  <main class="legal">
    <div class="shell-tight legal__inner reveal">
      <h1 class="legal__title">Privacy.</h1>
      <p class="legal__meta">Last updated {updated}</p>
      <p class="legal__lead">
        KP Solutions is a one-person software studio. This site doesn't track you.
        There are no analytics, no advertising pixels, and no cookies. The only
        information collected is what you choose to send through the contact form.
      </p>

      <h2>What we collect</h2>
      <p>
        When you submit the contact form, we receive the details you enter: your
        name, your email address, an optional business name, and the message
        describing what you're working with. Nothing else is gathered, and we
        don't ask for anything we don't need to reply to you.
      </p>

      <h2>How it's used</h2>
      <p>
        Your submission is used for one purpose: to respond to your enquiry and,
        if it leads to work, to scope and run that engagement. It is never sold,
        rented, or shared for marketing.
      </p>

      <h2>Who processes it</h2>
      <p>
        The site is hosted on Cloudflare, and contact-form messages are delivered
        by email through Resend. Both act only as processors of the message in
        transit. Your enquiry then lives in our email inbox like any other
        message you'd send us directly.
      </p>

      <h2>How long it's kept</h2>
      <p>
        Enquiries are kept only as long as needed to handle your request and any
        resulting project. If a conversation doesn't go anywhere, the message is
        deleted in the normal course of clearing the inbox.
      </p>

      <h2>Your choices</h2>
      <p>
        You can ask us what we hold about you, or ask us to delete it, at any
        time — just email <a href={`mailto:${ORG_EMAIL}`}>{ORG_EMAIL}</a> and
        we'll handle it promptly.
      </p>

      <h2>Changes</h2>
      <p>
        If this policy changes, the updated version will be posted here with a new
        date. Questions about any of it are welcome at
        <a href={`mailto:${ORG_EMAIL}`}>{ORG_EMAIL}</a>.
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  import "../scripts/reveal.ts";
</script>
