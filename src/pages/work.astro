---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CaseHero from "../components/work/CaseHero.astro";
import CaseMeta from "../components/work/CaseMeta.astro";
import { caseStudies } from "../lib/work";
import { articleSchema, breadcrumbSchema, type JsonLdSchema } from "../lib/schema";
import "../styles/work.css";

const SITE = "https://kpsolutions.io";
const title = "Potter Sanctuary — KP Solutions";
const description =
  "Potter Sanctuary — a new wellness practice given a complete foundation: a branded editorial website engineered to be found and cited by AI search, an integrated booking system wired into the site, client accounts, and a self-serve admin portal.";

const schemas: JsonLdSchema[] = [
  articleSchema({
    headline: "Potter Sanctuary",
    description:
      "A new wellness practice given a complete foundation — a branded editorial website engineered to be cited by AI search, integrated booking, client accounts, and a self-serve admin portal.",
    url: `${SITE}/work`,
    datePublished: "2026-02-01",
    author: "KP Solutions",
  }),
  breadcrumbSchema([
    { name: "Home", url: `${SITE}/` },
    { name: "Work", url: `${SITE}/work` },
  ]),
];
---

<BaseLayout title={title} description={description} schemas={schemas}>
  <Header heroMode="dark" />
  <main>
    <CaseHero />
    <CaseMeta />
    <section class="case-studies" aria-label="Case studies">
      {
        caseStudies.map((cs) => (
          <article class="reveal case-entry">
            <h2 class="case-section-title case-entry__title">{cs.title}</h2>
            {cs.body.map((p) => (
              <p class="case-prose">{p}</p>
            ))}
          </article>
        ))
      }
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  import "../scripts/reveal.ts";
</script>
