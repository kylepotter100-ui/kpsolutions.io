---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProcessHero from "../components/process/ProcessHero.astro";
import ProcessWeeks from "../components/process/ProcessWeeks.astro";
import ProcessIncluded from "../components/process/ProcessIncluded.astro";
import ProcessCost from "../components/process/ProcessCost.astro";
import ProcessWhy from "../components/process/ProcessWhy.astro";
import ProcessClosing from "../components/process/ProcessClosing.astro";
import FAQ, { type FaqItem } from "../components/FAQ.astro";
import { serviceSchema, breadcrumbSchema, faqPageSchema, type JsonLdSchema } from "../lib/schema";
import "../styles/process.css";

const SITE = "https://kpsolutions.io";
const title = "Process — KP Solutions";
const description =
  "How we build — discovery, design, build, and launch. Scoped comprehensively, fixed fee, code owned by you, with a ninety-day post-launch guarantee.";

// Drawn from existing process copy (the four phases, what's included, cost,
// why-it-works) — no invented claims.
const faqItems: FaqItem[] = [
  {
    q: "What happens first?",
    a: "Discovery and architecture. A 30-minute call to see if we can help, then the brief written in your words and signed off, the data model drafted on paper, and a fixed-fee proposal within forty-eight hours.",
  },
  {
    q: "When do I see something real?",
    a: "Early on. A live staging URL goes up so you watch the build as it happens — real screens, not wireframes.",
  },
  {
    q: "What do I get at handover?",
    a: "Production cutover with you on the call, the source repository transferred to your organisation, a runbook, a Loom walkthrough, and a ninety-day post-launch guarantee that starts the moment you are live.",
  },
  {
    q: "How is it priced?",
    a: "Every engagement is a fixed fee, scoped up front and agreed before any build work begins. No retainers, no monthly invoices, no scope-creep clauses.",
  },
  {
    q: "Why a fixed scope?",
    a: "A tight, fixed scope is the constraint that makes the rest possible. It rules out the discovery phase that produces nothing and the replatform that ships eighteen months late, and it keeps scope set up front and respected throughout.",
  },
  {
    q: "Who actually does the work?",
    a: "One person, operator to operator. Decisions are made on the call, not in a status report, with no account managers or hand-offs in between.",
  },
];

const schemas: JsonLdSchema[] = [
  serviceSchema({
    name: "How we build",
    description:
      "Four phases — discovery and architecture, design, build, then launch and handover. Scoped comprehensively, fixed fee, code owned by you, with a ninety-day post-launch guarantee.",
    url: `${SITE}/process`,
    serviceType: "Custom software development",
  }),
  faqPageSchema(faqItems.map((it) => ({ question: it.q, answer: it.a }))),
  breadcrumbSchema([
    { name: "Home", url: `${SITE}/` },
    { name: "Process", url: `${SITE}/process` },
  ]),
];
---

<BaseLayout title={title} description={description} schemas={schemas}>
  <Header heroMode="light" />
  <main>
    <ProcessHero />
    <ProcessWeeks />
    <ProcessIncluded />
    <ProcessCost />
    <ProcessWhy />
    <FAQ items={faqItems} />
    <ProcessClosing />
  </main>
  <Footer />
</BaseLayout>

<script>
  import "../scripts/reveal.ts";
</script>
