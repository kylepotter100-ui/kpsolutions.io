---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ServicesHero from "../components/services/ServicesHero.astro";
import ServicesPassage from "../components/services/ServicesPassage.astro";
import ServicesIndex from "../components/services/ServicesIndex.astro";
import CustomPlatforms from "../components/services/CustomPlatforms.astro";
import InternalTools from "../components/services/InternalTools.astro";
import AIVisible from "../components/services/AIVisible.astro";
import Integrations from "../components/services/Integrations.astro";
import LegacyReplacement from "../components/services/LegacyReplacement.astro";
import ServicesClosing from "../components/services/ServicesClosing.astro";
import FAQ, { type FaqItem } from "../components/FAQ.astro";
import { serviceSchema, breadcrumbSchema, faqPageSchema, type JsonLdSchema } from "../lib/schema";
// homepage.css carries the .hero-bg-* and .pinned* primitives reused by
// ServicesHero and ServicesPassage; services.css holds the page-specific rules.
import "../styles/homepage.css";
import "../styles/services.css";

const SITE = "https://kpsolutions.io";
const title = "Services — KP Solutions";
const description =
  "Five shapes of bespoke software — custom platforms, internal tools, AI-visible web presence, integrations and automation, and phased legacy replacement. Fixed fee, scoped comprehensively, code owned by you.";

// Drawn from existing site copy (four-week process, ownership, the five shapes,
// phased legacy replacement, AI-visible web presence) — no invented claims.
const faqItems: FaqItem[] = [
  {
    q: "How long will my project take?",
    a: "Every project is scoped comprehensively, and the delivery timeline is set out in a written proposal before any work begins — so you have the schedule up front, with no guesswork.",
  },
  {
    q: "Who owns the code?",
    a: "You do, from day one. The source repository is transferred to your organisation at launch, with a runbook and a walkthrough. No lock-in, no per-seat licence on your own software.",
  },
  {
    q: "What does it cost?",
    a: "A fixed fee, agreed before the build starts and scoped to the project. You know the number up front, with no hourly surprises.",
  },
  {
    q: "What kinds of software do you build?",
    a: "Five shapes: custom platforms, internal tools, AI-visible web presence, integrations and automation, and phased legacy replacement. If your problem doesn't match a shape, that's the conversation worth having.",
  },
  {
    q: "Can you replace our existing SaaS without a long migration?",
    a: "Yes, in pieces. We cut over one workflow at a time, starting with the worst fit, and the old system stays live until the new one is honestly better. No sixteen-month replatform.",
  },
  {
    q: "What makes a site AI-visible?",
    a: "It is engineered so AI search engines — ChatGPT, Claude, Perplexity, Google AI Overviews — can read exactly what you do and recommend you by name, not just list you on a results page. Structured content and direct answers they can quote, under the hood.",
  },
];

const schemas: JsonLdSchema[] = [
  serviceSchema({
    name: "Bespoke software",
    description:
      "Custom platforms, internal tools, AI-visible web presence, integrations and automation, and phased legacy replacement, built around how your operation actually works.",
    url: `${SITE}/services`,
    serviceType: "Custom software development",
  }),
  faqPageSchema(faqItems.map((it) => ({ question: it.q, answer: it.a }))),
  breadcrumbSchema([
    { name: "Home", url: `${SITE}/` },
    { name: "Services", url: `${SITE}/services` },
  ]),
];
---

<BaseLayout title={title} description={description} schemas={schemas}>
  <Header heroMode="dark" />
  <main>
    <ServicesHero />
    <ServicesPassage />
    <ServicesIndex />
    <CustomPlatforms />
    <InternalTools />
    <AIVisible />
    <Integrations />
    <LegacyReplacement />
    <FAQ items={faqItems} />
    <ServicesClosing />
  </main>
  <Footer />
</BaseLayout>

<script>
  import "../scripts/reveal.ts";
</script>
