---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactHero from "../components/contact/ContactHero.astro";
import ContactMain from "../components/contact/ContactMain.astro";
import ContactNote from "../components/contact/ContactNote.astro";
import { breadcrumbSchema, type JsonLdSchema } from "../lib/schema";
import "../styles/contact.css";

const SITE = "https://kpsolutions.io";
const title = "Start a conversation — KP Solutions";
const description =
  "A 30-minute call to see if we can help. No slides, no discovery deck. A written proposal within 48 hours.";

const schemas: JsonLdSchema[] = [
  breadcrumbSchema([
    { name: "Home", url: `${SITE}/` },
    { name: "Contact", url: `${SITE}/contact` },
  ]),
];
---

<BaseLayout title={title} description={description} schemas={schemas}>
  <Header heroMode="light" />
  <main>
    <ContactHero />
    <ContactMain />
    <ContactNote />
  </main>
  <Footer />
</BaseLayout>

<script>
  import "../scripts/reveal.ts";
</script>
