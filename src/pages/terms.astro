---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { breadcrumbSchema, type JsonLdSchema } from "../lib/schema";
import { ORG_EMAIL } from "../lib/site";
import "../styles/legal.css";

const SITE = "https://kpsolutions.io";
const title = "Terms — KP Solutions";
const description =
  "The terms for using the KP Solutions website. Project work is governed by a separate written agreement.";

const schemas: JsonLdSchema[] = [
  breadcrumbSchema([
    { name: "Home", url: `${SITE}/` },
    { name: "Terms", url: `${SITE}/terms` },
  ]),
];

const updated = "June 2026";
---

<BaseLayout title={title} description={description} schemas={schemas}>
  <Header heroMode="light" />
  <main class="legal">
    <div class="shell-tight legal__inner reveal">
      <h1 class="legal__title">Terms.</h1>
      <p class="legal__meta">Last updated {updated}</p>
      <p class="legal__lead">
        These terms cover your use of this website. They're deliberately short.
        Any actual project work is governed by a separate written proposal and
        agreement — not by this page.
      </p>

      <h2>The website</h2>
      <p>
        This site is informational. The descriptions of what KP Solutions builds,
        how the studio works, and the case study shown are provided to help you
        decide whether to get in touch. Nothing here is a binding offer, quote, or
        guarantee of a specific outcome.
      </p>

      <h2>Engagements</h2>
      <p>
        When we work together, the scope, fee, timeline, and terms are set out in
        a written proposal and agreement specific to your project. Those documents
        govern the engagement. A consistent principle across them: the source code
        we build for you is owned by you.
      </p>

      <h2>Intellectual property</h2>
      <p>
        The content, design, and branding of this website are owned by KP
        Solutions. The Potter Sanctuary case study is published with the client's
        permission. Please don't reproduce the site's content without asking.
      </p>

      <h2>Third-party links</h2>
      <p>
        Where this site links out — for example to a live client site — we aren't
        responsible for the content or practices of those external pages.
      </p>

      <h2>Liability</h2>
      <p>
        The website is provided as-is. To the extent permitted by law, KP
        Solutions isn't liable for any loss arising from reliance on the
        informational content of this site. This doesn't limit anything that
        can't be limited by law.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about these terms are welcome at
        <a href={`mailto:${ORG_EMAIL}`}>{ORG_EMAIL}</a>.
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  import "../scripts/reveal.ts";
</script>
