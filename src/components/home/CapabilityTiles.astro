---
// "What we build" — a content-sized list. Heading + hairline, then each service
// (name, then its Challenge / Offer / Outcome sub-sections) in normal flow. No pin,
// no scroll-jacking: the section is sized by its content + padding. Each service
// fades in on scroll-enter via the shared .reveal-stagger / inView system. Copy from
// capabilities.ts.
import { capabilities } from "../../lib/capabilities";
---

<section id="capabilities" class="wwb" aria-labelledby="wwb-heading">
  <div class="wwb__inner shell">
    <h2 id="wwb-heading" class="section-heading wwb__heading">What we build.</h2>
    <div class="wwb__rule" aria-hidden="true"></div>
    {
      capabilities.map((s) => (
        <article class="wwb-service reveal-stagger">
          <h3 class="wwb-service__name">
            {s.lead} <span class="display-italic">{s.accent}</span>.
          </h3>
          <div class="wwb-service__subs">
            {s.subs.map((sub) => (
              <div class="wwb-sub">
                <h4 class="wwb-sub__label">{sub.label}</h4>
                <p class="wwb-sub__body">{sub.body}</p>
              </div>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</section>
