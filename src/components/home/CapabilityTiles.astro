---
// "What we build" — content-height centred pinned scrollytelling, ported from
// docs/references/what-we-build-collapse.html. Three mechanisms:
//  1. Content-height centred pin (.wwb__pin: sticky top:50% + translateY(-50%),
//     own bone bg + z-index) — compact visible area, no empty 100vh frame.
//  2. Per-service entry hold — each service starts fresh (first sub never pre-
//     collapsed); collapse only begins after the hold (see reveal.ts).
//  3. Keep-last-sub-visible collapse (collapsible = nSub-1) — right column never
//     empty, left title never alone.
// Animation is transform/opacity only; offsets cached on init + resize + fonts.
// The service count drives the scroll height via --wwb-acts. Mobile / reduced-
// motion / no-JS render the static interleaved list. Copy from capabilities.ts.
import { capabilities } from "../../lib/capabilities";
---

<section id="capabilities" class="wwb" data-wwb aria-labelledby="wwb-heading">
  <div class="wwb__outer" data-wwb-outer style={`--wwb-acts:${capabilities.length}`}>
    <div class="wwb__pin">
      <div class="wwb__inner shell">
        <h2 id="wwb-heading" class="section-heading wwb__heading">What we build.</h2>
        <div class="wwb__rule" aria-hidden="true"></div>
        <div class="wwb__stage" data-wwb-stage>
          {
            capabilities.map((s, i) => (
              <article class={i === 0 ? "wwb-service is-active" : "wwb-service"} data-wwb-group>
                <h3 class="wwb-service__name">
                  {s.lead} <span class="display-italic">{s.accent}</span>.
                </h3>
                <div class="wwb-subs" data-wwb-subs>
                  <div class="wwb-subs__track" data-wwb-track>
                    {s.subs.map((sub) => (
                      <div class="wwb-sub" data-wwb-sub>
                        <h4 class="wwb-sub__label">{sub.label}</h4>
                        <p class="wwb-sub__body">{sub.body}</p>
                      </div>
                    ))}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
