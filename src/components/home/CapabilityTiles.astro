---
// "What we build" — left/right pinned scrollytelling (Darktrace-style). Each
// service is one <article> (name + its three subs together), so the same markup
// is a clean interleaved static list in fallback AND an overlaid two-column stage
// under JS. On desktop the section pins: the left column shows the active service
// name (cross-fades on change) and the right column's three sub-sections collapse
// upward via transform + opacity only (driven by reveal.ts initWhatWeBuild). The
// service count drives the scroll height via --wwb-acts. Mobile / reduced-motion /
// no-JS render the static expanded list. Copy + ids come from capabilities.ts.
import { capabilities } from "../../lib/capabilities";
---

<section id="capabilities" class="wwb" data-wwb aria-labelledby="wwb-heading">
  <div class="wwb__outer" style={`--wwb-acts:${capabilities.length}`}>
    <div class="wwb__pin">
      <div class="wwb__stage shell">
        <h2 id="wwb-heading" class="wwb__eyebrow">What we build.</h2>
        {
          capabilities.map((s, i) => (
            <article class={i === 0 ? "wwb-service is-active" : "wwb-service"} data-wwb-group>
              <div class="wwb-service__head">
                <h3 class="wwb-service__name">
                  {s.lead} <span class="display-italic">{s.accent}</span>.
                </h3>
              </div>
              <div class="wwb-service__subs" data-wwb-subs>
                {s.subs.map((sub) => (
                  <div class="wwb-sub" data-wwb-sub>
                    <h4 class="wwb-sub__label">{sub.label}</h4>
                    <p class="wwb-sub__body">{sub.body}</p>
                  </div>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
