---
// "What we build" — natural-reflow scrollytelling. The section pins for the
// scroll duration; every sub-section starts expanded in normal document flow,
// then collapses one at a time (top to bottom) as you scroll, letting the
// content below reflow upward to fill the space. By the end only the service
// names remain. Driven by reveal.ts initWhatWeBuild (desktop only, count-driven).
// Mobile / reduced-motion / no-JS / WWB_COLLAPSE=false render every sub-section
// static and fully expanded with no pinning or clipping. Copy + ids come from
// capabilities.ts, the single source shared with the Service JSON-LD.
import { capabilities } from "../../lib/capabilities";
---

<section id="capabilities" class="wwb" data-wwb aria-labelledby="wwb-heading">
  <div class="wwb__outer">
    <div class="wwb__pin">
      <div class="wwb__content shell">
        <h2 id="wwb-heading" class="section-heading wwb__heading">What we build.</h2>
        {
          capabilities.map((s) => (
            <article class="wwb-service reveal">
              <h3 class="wwb-service__name">
                {s.lead} <span class="display-italic">{s.accent}</span>.
              </h3>
              {s.subs.map((sub) => (
                <div class="wwb-sub" data-wwb-sub>
                  <h4 class="wwb-sub__label">{sub.label}</h4>
                  <p class="wwb-sub__body">{sub.body}</p>
                </div>
              ))}
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
