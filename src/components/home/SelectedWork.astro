---
import Icon from "../Icon.astro";
import ScrollingShot from "../ScrollingShot.astro";
import { PS_SHOT, PS_DOMAIN } from "../../lib/work";
---

<section id="work" class="bg-bone-0 pt-40 pb-35">
  <div class="shell-wide">
    <div class="reveal flex justify-between items-baseline flex-wrap gap-8 mb-14" style="padding: 0 32px;">
      <h2 class="section-heading max-w-[20ch]">Selected work.</h2>
      <a href="/work" class="link-arrow">All work <Icon name="arrow-right" size={14} /></a>
    </div>

    <div class="reveal" style="padding: 0 32px;">
      <div class="screenshot-placeholder" aria-label="Potter Sanctuary — live site preview">
        <ScrollingShot
          src={PS_SHOT}
          alt="Live preview of the Potter Sanctuary homepage, scrolling through the landing page"
          urlLabel={PS_DOMAIN}
          urlPosition="top-right"
          duration={30}
        />
      </div>
    </div>

    <div class="reveal grid grid-cols-2 max-[960px]:grid-cols-1 gap-16 items-start mt-12 max-w-[1100px]" style="padding: 0 32px;">
      <div>
        <a href="/work" class="work-title-link">Potter Sanctuary <Icon name="arrow-right" size={16} /></a>
      </div>
      <p class="work-desc">
        A UK business needing brand, editorial site, integrated bookings,
        customer accounts, and admin tooling. Built and shipped in four weeks.
      </p>
    </div>
  </div>
</section>
