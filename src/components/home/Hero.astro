---
import Button from "../Button.astro";

// Above-the-fold copy is static (no reveal gating) — crawler-safe.
// Hero grain is a tiled CSS texture (see .hero-bg-grain in homepage.css).
---

<section id="top" class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-bg-field"></div>
    <div class="hero-bg-glow"></div>
    <div class="hero-bg-grain"></div>
    <div class="hero-bg-scrim"></div>
    <div class="placeholder-label placeholder-label--hero">
      <span class="placeholder-label__dot"></span>
      <span>Hero video loop&nbsp;&nbsp;·&nbsp;&nbsp;Hands at craft, warm tonal light&nbsp;&nbsp;·&nbsp;&nbsp;10–12 s seamless</span>
    </div>
  </div>

  <div class="hero-content">
    <h1 class="hero-headline">
      Software that fits <span class="hero-italic">how you work</span>.
    </h1>

    <p class="hero-sub">
      Bespoke platforms, internal tools, and integrations — plus web presence
      engineered to be found by AI. Built in four weeks. Owned by you.
    </p>

    <div class="hero-cta-row">
      <Button href="/contact" variant="hero-primary" icon="arrow-right">Start a conversation</Button>
    </div>
  </div>
</section>
