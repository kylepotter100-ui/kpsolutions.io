---
const cards = [
  {
    title: "Just starting out",
    desc: "Get the software and AI-visible web presence that puts you in front of customers from day one.",
  },
  {
    title: "Growing fast",
    desc: "Replace the spreadsheets and stitched-together SaaS before they slow you down.",
  },
  {
    title: "Off-the-shelf isn't fitting",
    desc: "Bespoke is the right answer, and it's faster than you think.",
  },
  {
    title: "Need fully custom for unique operations",
    desc: "Software designed around how your business actually works, not what a vendor was willing to sell.",
  },
];
---

<section class="who" aria-labelledby="who-heading">
  <div class="shell">
    <h2 id="who-heading" class="section-heading who__heading">Who we work with.</h2>
    <div class="who-grid">
      {
        cards.map((c) => (
          <article class="who-card">
            <h3 class="who-card__title">{c.title}</h3>
            <p class="who-card__desc">{c.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
