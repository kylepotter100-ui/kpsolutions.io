---
import Icon from "../Icon.astro";
---

<section id="contact" class="closing-cta closing-cta--bright">
  <div class="shell">
    <div class="reveal closing-cta__inner">
      <p class="closing-cta__eyebrow">Your business. Your software.</p>
      <h2 class="closing-cta__title">
        Tell me what you <span class="display-italic">need built</span>.
      </h2>
      <p class="closing-cta__sub">
        A 90-minute conversation. No slides, no discovery deck. A written
        proposal within 48 hours.
      </p>
      <a href="/contact" class="btn btn-inverse" style="font-size: 15px; padding: 18px 28px;">
        Start a conversation <Icon name="arrow-right" size={14} />
      </a>
    </div>
  </div>
</section>
