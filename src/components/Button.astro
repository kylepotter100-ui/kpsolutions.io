---
import Icon from "./Icon.astro";

interface Props {
  href: string;
  variant?: "primary" | "secondary" | "inverse" | "hero-primary";
  icon?: string;
  iconSize?: number;
  class?: string;
}
const { href, variant = "primary", icon, iconSize = 14, class: className } = Astro.props;
---

<a href={href} class:list={["btn", `btn-${variant}`, className]}>
  <slot />{icon && <Icon name={icon} size={iconSize} />}
</a>
