---
// Auto-scrolling screenshot: a tall full-page screenshot that scrolls
// vertically on a loop inside a clipped frame (fills its positioned parent).
// motion-driven so the scroll distance adapts to the image + frame size, and
// the duration is derived from that distance so the speed stays consistent
// across very different captures. Reduced-motion shows the top, static.
// A desktop capture (wide) is the default; an optional mobile capture
// (single-column) is served to phones via <picture>.
interface Props {
  src: string;
  srcMobile?: string;
  alt: string;
  urlLabel?: string;
  urlPosition?: "top-right" | "bottom-left";
  eager?: boolean;
  class?: string;
}
const {
  src,
  srcMobile,
  alt,
  urlLabel,
  urlPosition = "top-right",
  eager = false,
  class: className,
} = Astro.props;
---

<div class:list={["pshot", className, !srcMobile && "pshot--desktop-only"]} data-pshot>
  <picture>
    {srcMobile && <source srcset={srcMobile} media="(max-width: 700px)" />}
    <img
      class="pshot__img"
      src={src}
      alt={alt}
      data-pshot-img
      loading={eager ? "eager" : "lazy"}
      decoding="async"
      fetchpriority={eager ? "high" : "auto"}
    />
  </picture>
  {urlLabel && <span class:list={["pshot__url", `pshot__url--${urlPosition}`]}>{urlLabel}</span>}
</div>

<style>
  .pshot { position: absolute; inset: 0; overflow: hidden; background: var(--bone-100); }
  .pshot picture { display: contents; }
  .pshot__img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: auto;
    display: block;
    will-change: transform;
  }
  .pshot__url {
    position: absolute;
    z-index: 3;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: oklch(96% 0.012 60 / 0.78);
    background: oklch(13% 0.025 22 / 0.55);
    padding: 5px 10px;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .pshot__url--top-right { top: 20px; right: 20px; }
  .pshot__url--bottom-left { left: 20px; bottom: 20px; }

  /* No mobile capture supplied: zoom the desktop capture slightly on phones so
     it reads larger instead of tiny. When a mobile capture is served, it
     already fits, so this is skipped. */
  @media (max-width: 700px) {
    .pshot--desktop-only .pshot__img { width: 125%; left: -12.5%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pshot__img { transform: none !important; }
  }
</style>

<script>
  import { animate, inView } from "motion";

  const SPEED = 120; // px/second — keeps the scroll feel consistent across captures

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  document.querySelectorAll<HTMLElement>("[data-pshot]").forEach((shot) => {
    const img = shot.querySelector<HTMLImageElement>("[data-pshot-img]");
    if (!img) return;
    let controls: ReturnType<typeof animate> | null = null;
    let visible = false;

    // (Re)build the loop sized to the current image + frame. Duration is
    // derived from the scroll distance so speed is constant. Starts paused;
    // play/pause is driven by whether the section is in view.
    const build = () => {
      controls?.stop();
      controls = null;
      if (reduce) return;
      const dist = img.offsetHeight - shot.offsetHeight;
      if (dist <= 4) return;
      const duration = Math.min(Math.max(dist / SPEED, 16), 80);
      controls = animate(
        img,
        { y: [0, -dist] },
        { duration, ease: "linear", repeat: Infinity, repeatType: "reverse" },
      );
      if (visible) controls.play();
      else controls.pause();
    };

    // Build on initial load and whenever the source swaps (e.g. <picture>
    // crossing the breakpoint), which fires a fresh load event.
    if (img.complete && img.naturalHeight) build();
    img.addEventListener("load", build);

    // Only scroll the project while the section is on screen.
    inView(
      shot,
      () => {
        visible = true;
        controls?.play();
        return () => {
          visible = false;
          controls?.pause();
        };
      },
      { amount: 0.2 },
    );

    // Rebuild only when the width changes. Mobile browsers fire `resize` on
    // every scroll as the URL bar shows/hides (height-only); rebuilding on
    // those restarted the loop from the top — the "glitch back to start".
    let t = 0;
    let lastW = window.innerWidth;
    window.addEventListener(
      "resize",
      () => {
        if (window.innerWidth === lastW) return;
        lastW = window.innerWidth;
        clearTimeout(t);
        t = window.setTimeout(build, 200);
      },
      { passive: true },
    );
  });
</script>
