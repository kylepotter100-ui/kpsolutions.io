---
import { ORG_EMAIL } from "../lib/site";

const navLinks = [
  { label: "Work", href: "/work" },
  { label: "Services", href: "/services" },
  { label: "Process", href: "/process" },
  { label: "Contact", href: "/contact" },
];
---

<footer>
  <div class="inner">
    <div class="top">
      <div>
        <div class="wordmark">
          <span class="wordmark__mark" aria-hidden="true"></span>
          KP Solutions
        </div>
        <p class="tagline">Bespoke software for how your business actually works.</p>
      </div>
      <div class="contact">
        <a href={`mailto:${ORG_EMAIL}`} class="email">{ORG_EMAIL}</a>
        <a href="/contact" class="cta">
          Start a conversation
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <nav class="links" aria-label="Footer">
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="legal">
      <span>© 2026 KP Solutions · Loughborough, UK</span>
      <div class="legal-links">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--ink-0);
    color: var(--ink-900);
    border-top: 1px solid oklch(0% 0 0 / 0.06);
  }
  .inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 64px 32px 36px;
  }
  .top {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 48px;
    align-items: end;
    padding-bottom: 44px;
    border-bottom: 1px solid oklch(0% 0 0 / 0.06);
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.25rem);
    font-weight: 500;
    letter-spacing: -0.028em;
    line-height: 1;
    color: var(--ink-900);
  }
  .wordmark__mark {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    background: var(--lime-500);
    box-shadow: inset 0 0 0 1px oklch(40% 0.18 124 / 0.18);
  }
  .tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 0.9rem + 0.6vw, 1.375rem);
    letter-spacing: -0.018em;
    line-height: 1.25;
    color: var(--ink-500);
    margin: 16px 0 0;
    max-width: 26ch;
  }
  .contact {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
    padding-bottom: 4px;
  }
  .email {
    font-size: 16px;
    font-weight: 500;
    color: var(--ink-900);
    text-decoration: underline;
    text-decoration-color: var(--lime-500);
    text-underline-offset: 0.3em;
    text-decoration-thickness: 2px;
    display: inline-flex;
    align-items: center;
    min-height: 36px;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.003em;
    color: var(--ink-900);
    background: var(--lime-500);
    text-decoration: none;
    border: 1px solid var(--lime-500);
    transition: background 180ms var(--ease-out), border-color 180ms var(--ease-out);
  }
  .cta:hover { background: var(--lime-400); border-color: var(--lime-400); }

  .links {
    padding: 32px 0;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 40px;
    border-bottom: 1px solid oklch(0% 0 0 / 0.06);
  }
  .links a {
    font-size: 14.5px;
    font-weight: 500;
    color: var(--ink-700);
    text-decoration: none;
    letter-spacing: -0.005em;
    transition: color 160ms var(--ease-out);
    display: inline-flex;
    align-items: center;
    min-height: 36px;
  }
  .links a:hover { color: var(--lime-700); }

  .legal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 28px;
    gap: 24px;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--ink-400);
    letter-spacing: -0.003em;
  }
  .legal-links { display: flex; gap: 24px; }
  .legal-links a {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    transition: color 160ms var(--ease-out);
  }
  .legal-links a:hover { color: var(--ink-700); }

  @media (max-width: 960px) {
    .top { grid-template-columns: 1fr; gap: 40px; align-items: start; }
  }
</style>
