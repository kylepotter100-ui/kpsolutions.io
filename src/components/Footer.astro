---
import Icon from "./Icon.astro";
import { ORG_EMAIL } from "../lib/site";

const navLinks = [
  { label: "Work", href: "/work" },
  { label: "Services", href: "/services" },
  { label: "Process", href: "/process" },
  { label: "Contact", href: "/contact" },
];
---

<footer>
  <div class="inner">
    <div class="top">
      <div>
        <div class="wordmark">KP Solutions</div>
        <p class="tagline">Bespoke software for how your business actually works.</p>
      </div>
      <div class="contact">
        <a href={`mailto:${ORG_EMAIL}`} class="email">{ORG_EMAIL}</a>
        <a href="/contact" class="btn btn-inverse cta">Start a conversation <Icon name="arrow-right" size={14} /></a>
      </div>
    </div>

    <nav class="links" aria-label="Footer">
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="legal">
      <span>© 2026 KP Solutions</span>
      <div class="legal-links">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Shared deep field (also used by the dedicated-page closings) so the closing
     CTA flows into the footer with no colour seam. */
  footer {
    background: var(--field-deep);
    color: var(--bone-0);
  }
  .inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 64px 32px 36px;
  }
  .top {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 48px;
    align-items: end;
    padding-bottom: 44px;
    border-bottom: 1px solid oklch(98.5% 0.008 60 / 0.16);
  }
  .wordmark {
    font-size: clamp(1.75rem, 1.2rem + 2vw, 2.75rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--bone-0);
  }
  .tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.05rem, 0.9rem + 0.6vw, 1.375rem);
    letter-spacing: -0.018em;
    line-height: 1.2;
    color: oklch(96% 0.012 60 / 0.74);
    margin: 14px 0 0;
    max-width: 26ch;
  }
  .contact {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
    padding-bottom: 8px;
  }
  .email {
    font-size: 17px;
    font-weight: 500;
    color: var(--bone-0);
    text-decoration: underline;
    text-decoration-color: oklch(96% 0.012 60 / 0.35);
    text-underline-offset: 0.3em;
    text-decoration-thickness: 1px;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .cta { padding: 15px 24px; font-size: 14px; }

  .links {
    padding: 32px 0;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 40px;
    border-bottom: 1px solid oklch(98.5% 0.008 60 / 0.16);
  }
  .links a {
    font-size: 15px;
    font-weight: 500;
    color: var(--bone-0);
    text-decoration: none;
    letter-spacing: -0.005em;
    transition: color 160ms var(--ease-out);
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .links a:hover { color: var(--ochre-300); }

  .legal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 28px;
    gap: 24px;
    flex-wrap: wrap;
    font-size: 13px;
    color: oklch(96% 0.012 60 / 0.72);
    letter-spacing: -0.003em;
  }
  .legal-links { display: flex; gap: 24px; }
  .legal-links a {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }

  @media (max-width: 960px) {
    .top { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
