---
import GrainSurface from "../GrainSurface.astro";
import PlaceholderLabel from "../PlaceholderLabel.astro";

const grain = "0 0 0 0 0.95  0 0 0 0 0.85  0 0 0 0 0.75  0 0 0 0.4 0";
---

<section aria-label="Atmospheric break" class="process-break">
  <div class="process-break__surface">
    <GrainSurface id="process-break-grain" baseFrequency={0.85} seed={151} matrix={grain} class="process-break__grain" />
    <div class="process-break__scrim"></div>
    <PlaceholderLabel tone="light" position="bottom-left">
      Atmospheric — completed work in operational use, golden hour
    </PlaceholderLabel>
  </div>
</section>
