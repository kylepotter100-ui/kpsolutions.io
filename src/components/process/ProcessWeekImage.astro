---
interface Props {
  surface: string;
  marker: string;
}
const { surface, marker } = Astro.props;
---

<div class="process-week__image">
  <div class="process-week__sticky">
    <div class:list={["brand-field", `brand-field--${surface}`]}>
      <div class="grain-overlay" aria-hidden="true"></div>
      <div class="brand-field__scrim"></div>
      <div class="brand-field__mark" aria-hidden="true">{marker}</div>
    </div>
  </div>
</div>
