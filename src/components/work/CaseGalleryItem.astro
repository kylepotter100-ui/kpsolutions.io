---
interface Props {
  id: string;
  surface: string;
  url?: string | null;
  caption: string;
}
const { surface, url, caption } = Astro.props;
---

<div class="case-gallery__item">
  <div class="reveal case-gallery__image-wrap">
    <div class:list={["brand-field", `brand-field--${surface}`]}>
      <div class="grain-overlay" aria-hidden="true"></div>
      <div class="brand-field__scrim"></div>
      {url && <div class="case-gallery__url">{url}</div>}
    </div>
  </div>

  <div class="shell case-gallery__caption-row">
    <p class="case-gallery__caption">{caption}</p>
  </div>
</div>
