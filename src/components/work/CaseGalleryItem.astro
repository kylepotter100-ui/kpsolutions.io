---
import GrainSurface from "../GrainSurface.astro";
import PlaceholderLabel from "../PlaceholderLabel.astro";

interface Props {
  id: string;
  surface: string;
  label: string;
  url?: string | null;
  caption: string;
}
const { id, surface, label, url, caption } = Astro.props;
const grain = "0 0 0 0 0.95  0 0 0 0 0.85  0 0 0 0 0.75  0 0 0 0.42 0";
const seed = id.length * 7;
---

<div class="case-gallery__item">
  <div class="reveal case-gallery__image-wrap">
    <div class:list={["placeholder-surface", `placeholder-surface--${surface}`]}>
      <GrainSurface id={`gallery-grain-${id}`} baseFrequency={0.9} seed={seed} matrix={grain} class="placeholder-surface__grain" />
      <div class="placeholder-surface__scrim"></div>
      {url && <div class="case-gallery__url">{url}</div>}
      <PlaceholderLabel tone="light" position="bottom-left">{label}</PlaceholderLabel>
    </div>
  </div>

  <div class="shell case-gallery__caption-row">
    <p class="case-gallery__caption">{caption}</p>
  </div>
</div>
