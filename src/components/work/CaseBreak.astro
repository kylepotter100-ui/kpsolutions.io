---
import GrainSurface from "../GrainSurface.astro";
import PlaceholderLabel from "../PlaceholderLabel.astro";

const grain = "0 0 0 0 0.95  0 0 0 0 0.85  0 0 0 0 0.75  0 0 0 0.4 0";
---

<section aria-label="Atmospheric break" class="case-break">
  <div class="case-break__surface">
    <GrainSurface id="case-break-grain" baseFrequency={0.85} seed={89} matrix={grain} class="case-break__grain" />
    <div class="case-break__scrim"></div>
    <PlaceholderLabel tone="light" position="bottom-left">
      Atmospheric — physical Potter Sanctuary detail or process moment
    </PlaceholderLabel>
  </div>
</section>
