---
import Icon from "../Icon.astro";
---

<section class="case-closing">
  <div class="shell">
    <div class="reveal case-closing__inner">
      <h2 class="case-closing__title">
        Four weeks. Brief to live. <span class="case-italic">Yours next.</span>
      </h2>
      <a href="/contact" class="btn btn-primary" style="font-size: 15px; padding: 18px 28px; margin-top: 48px;">
        Start a conversation <Icon name="arrow-right" size={14} />
      </a>
    </div>
  </div>
</section>
