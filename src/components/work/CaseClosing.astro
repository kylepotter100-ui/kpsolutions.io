---
import Icon from "../Icon.astro";
---

<section id="closing" class="case-closing">
  <div class="reveal case-closing__inner">
    <h2 class="case-closing__title">
      Want something <span class="case-closing__italic">like this</span>?
    </h2>
    <p class="case-closing__body">
      Tell us what you're working with. We'll let you know what shape the answer
      takes — and whether we're the right people to build it.
    </p>
    <a href="/contact" class="btn btn-primary" style="font-size: 15px; padding: 18px 28px;">
      Start a conversation <Icon name="arrow-right" size={14} />
    </a>
  </div>
</section>
