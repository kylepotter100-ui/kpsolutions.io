---
// Designer annotation inside an image / video region (not chrome).
// Ported from designs/core.jsx PlaceholderLabel.
interface Props {
  tone?: "light" | "dark";
  position?: "bottom-left" | "bottom-right" | "top-left" | "top-right";
}
const { tone = "light", position = "bottom-left" } = Astro.props;
---

<div class:list={["placeholder-label", `placeholder-label--${tone}`, `placeholder-label--${position}`]}>
  <span class="placeholder-label__dot"></span>
  <span><slot /></span>
</div>
