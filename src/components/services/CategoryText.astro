---
// Shared text block + kinetic word-cycler for a service category.
//
// Layout: two-column grid (~1180px). Left = numbered ochre eyebrow + serif-
// italic title + plain-language description. Right = overline + a kinetic
// panel where five examples cycle in place in large display type. All five
// words are server-rendered (AEO/crawler-safe); the cycler is pure CSS,
// zero JS, with a reduced-motion fallback that renders the words as a static
// stacked list.
interface Props {
  num: string;
  overline: string;
  body: string;
  words: string[];
}
const { num, overline, body, words } = Astro.props;
---

<div class="services-cat__inner">
  <div class="services-cat__text reveal">
    <p class="services-cat__eyebrow">{num} · Service</p>
    <h2 class="services-cat__title"><slot name="title" /></h2>
    <p class="services-cat__body">{body}</p>
  </div>

  <div class="services-cat__kinetic reveal" aria-hidden="false">
    <p class="services-cat__overline">{overline}</p>
    <div class="services-cat__cycler" aria-label="Examples">
      {
        words.map((w, i) => (
          <span class="services-cat__cycler-word" style={`--i:${i}`}>{w}</span>
        ))
      }
    </div>
  </div>
</div>
