---
// Slim numbered (01–05) anchor strip in a bordered, slightly-rounded
// container. data-svc-index hooks let initServicesIndex() in reveal.ts
// toggle .is-active on the link whose target section is currently in view
// (scroll-spy via the same `inView` import already used for .reveal).

const items = [
  { id: "custom-platforms", num: "01", label: "Custom platforms" },
  { id: "internal-tools", num: "02", label: "Internal tools" },
  { id: "aeo", num: "03", label: "AI-visible presence" },
  { id: "integrations", num: "04", label: "Integrations & automation" },
  { id: "legacy", num: "05", label: "Legacy replacement" },
];
---

<nav class="reveal services-index" aria-label="Services index">
  <div class="services-index__frame">
    <div class="services-index__grid">
      {
        items.map((it) => (
          <a href={`#${it.id}`} data-svc-index={it.id} class="services-index__link">
            <span class="services-index__num">{it.num}</span>
            <span class="services-index__label">{it.label}</span>
          </a>
        ))
      }
    </div>
  </div>
</nav>
