---
import Icon from "./Icon.astro";

interface Props {
  heroMode?: "dark" | "light";
}
const { heroMode = "dark" } = Astro.props;

const navItems = [
  { label: "Work", href: "/#work" },
  { label: "Build", href: "/build" },
  { label: "Process", href: "/process" },
  { label: "About", href: "/about" },
];
---

<header data-hero-mode={heroMode} class:list={[{ "is-past-hero": heroMode === "light" }]}>
  <div class="bar">
    <a href="/" class="logo">KP Solutions</a>

    <nav class="nav-desktop" aria-label="Primary">
      {navItems.map((it) => <a href={it.href} class="nav-link">{it.label}</a>)}
      <span class="divider" aria-hidden="true"></span>
      <a href="/contact" class="nav-cta">Start a conversation <Icon name="arrow-right" size={13} /></a>
    </nav>

    <button class="nav-mobile-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-sheet">
      <span class="icon-open"><Icon name="menu" size={22} /></span>
      <span class="icon-close"><Icon name="x" size={22} /></span>
    </button>
  </div>

  <div class="nav-mobile-sheet" id="mobile-sheet">
    <div class="sheet-inner">
      {navItems.map((it) => <a href={it.href} class="sheet-link">{it.label}</a>)}
      <a href="/contact" class="btn btn-primary sheet-cta">Start a conversation <Icon name="arrow-right" size={14} /></a>
    </div>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    color: var(--nav-fg);
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 220ms var(--ease-out), border-color 220ms var(--ease-out), color 220ms var(--ease-out);
    --nav-fg: var(--bone-0);
    --nav-muted: oklch(98.5% 0.006 60 / 0.92);
    --nav-divider: oklch(96% 0.012 60 / 0.3);
  }
  header.is-past-hero {
    background: oklch(98.5% 0.008 60 / 0.86);
    border-bottom-color: var(--bone-200);
    --nav-fg: var(--ox-900);
    --nav-muted: var(--bone-500);
    --nav-divider: var(--bone-200);
  }
  header.is-scrolled.is-past-hero {
    backdrop-filter: blur(12px) saturate(1.05);
    -webkit-backdrop-filter: blur(12px) saturate(1.05);
  }
  /* Transparent-over-hero state: scrim shadow so light nav text stays legible
     over a bright video frame, without losing the transparency aesthetic. */
  header:not(.is-past-hero) .logo,
  header:not(.is-past-hero) .nav-link,
  header:not(.is-past-hero) .nav-cta {
    text-shadow: 0 1px 14px oklch(8% 0.02 22 / 0.6), 0 0 2px oklch(8% 0.02 22 / 0.45);
  }

  .bar {
    max-width: 1280px;
    margin: 0 auto;
    padding: 8px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--nav-fg);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }

  .nav-desktop {
    display: flex;
    gap: 36px;
    align-items: center;
  }
  .nav-link {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: -0.003em;
    color: var(--nav-muted);
    text-decoration: none;
    transition: color 160ms var(--ease-out);
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .nav-link:hover { color: var(--nav-fg); }
  .divider {
    width: 1px;
    height: 14px;
    background: var(--nav-divider);
    display: inline-block;
  }
  .nav-cta {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.003em;
    color: var(--nav-fg);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    gap: 8px;
  }

  .nav-mobile-btn {
    display: none;
    background: none;
    border: 0;
    padding: 0;
    margin: 0;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--nav-fg);
  }
  .icon-close { display: none; }
  header.menu-open .icon-open { display: none; }
  header.menu-open .icon-close { display: inline-flex; }

  .nav-mobile-sheet {
    display: none;
    background: var(--bone-0);
    border-top: 1px solid var(--bone-200);
    color: var(--ox-900);
  }
  header.menu-open .nav-mobile-sheet { display: block; }
  .sheet-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 24px 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .sheet-link {
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.018em;
    color: var(--ox-900);
    text-decoration: none;
    display: flex;
    align-items: center;
    min-height: 44px;
  }
  .sheet-cta { margin-top: 12px; align-self: flex-start; }

  @media (max-width: 960px) {
    .nav-desktop { display: none; }
    .nav-mobile-btn { display: inline-flex; }
  }
  @media (min-width: 961px) {
    .nav-mobile-sheet { display: none !important; }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>("header[data-hero-mode]");
  if (header) {
    const mode = header.getAttribute("data-hero-mode");
    const onScroll = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 8);
      if (mode === "dark") {
        header.classList.toggle("is-past-hero", window.scrollY > window.innerHeight * 0.7);
      }
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    const btn = header.querySelector<HTMLButtonElement>(".nav-mobile-btn");
    const setMenu = (open: boolean) => {
      header.classList.toggle("menu-open", open);
      btn?.setAttribute("aria-expanded", String(open));
      btn?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    };
    btn?.addEventListener("click", () => setMenu(!header.classList.contains("menu-open")));
    header.querySelectorAll(".nav-mobile-sheet a").forEach((a) =>
      a.addEventListener("click", () => setMenu(false)),
    );
  }
</script>
