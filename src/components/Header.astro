---
import Icon from "./Icon.astro";

interface Props {
  // Retained for backwards-compat: every page still passes heroMode, but the
  // bar is now persistently dark, so the value is intentionally ignored.
  heroMode?: "dark" | "light";
}
// Three centred links; Contact is a standalone cream pill on the right.
const navItems = [
  { label: "Work", href: "/work" },
  { label: "Services", href: "/services" },
  { label: "Process", href: "/process" },
];
---

<header data-nav>
  <div class="bar">
    <a href="/" class="logo">KP Solutions</a>

    <nav class="nav-desktop" aria-label="Primary">
      {navItems.map((it) => <a href={it.href} class="nav-link">{it.label}</a>)}
    </nav>

    <a href="/contact" class="nav-cta">Contact</a>

    <button class="nav-mobile-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-sheet">
      <span class="icon-open"><Icon name="menu" size={22} /></span>
      <span class="icon-close"><Icon name="x" size={22} /></span>
    </button>
  </div>

  <div class="nav-mobile-sheet" id="mobile-sheet">
    <div class="sheet-inner">
      {navItems.map((it) => <a href={it.href} class="sheet-link">{it.label}</a>)}
      <a href="/contact" class="sheet-link sheet-link--cta">Contact</a>
    </div>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--ox-900);
    border-bottom: 1px solid var(--ox-500);
    color: var(--bone-0);
    -webkit-backdrop-filter: blur(0) saturate(1);
    backdrop-filter: blur(0) saturate(1);
    transition:
      backdrop-filter 220ms var(--ease-out),
      -webkit-backdrop-filter 220ms var(--ease-out),
      background 220ms var(--ease-out);
  }
  /* Past-hero / scrolled: slightly translucent + real blur so content ghosts
     behind the bar. Bar stays dark — no foreground colour flip. */
  header.is-scrolled {
    background: oklch(13% 0.025 22 / 0.82);
    -webkit-backdrop-filter: blur(10px) saturate(1.05);
    backdrop-filter: blur(10px) saturate(1.05);
  }
  header.is-past-hero {
    background: oklch(13% 0.025 22 / 0.7);
    -webkit-backdrop-filter: blur(16px) saturate(1.08);
    backdrop-filter: blur(16px) saturate(1.08);
  }

  .bar {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    padding: 8px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    position: relative;
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--bone-0);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    transition: color 200ms var(--ease-out);
  }

  /* Optically centred in the bar regardless of logo / CTA widths. */
  .nav-desktop {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 36px;
    align-items: center;
  }

  /* Contact — cream pill on the right so it stands out against the dark bar. */
  .nav-cta {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--ox-900);
    background: var(--bone-0);
    text-decoration: none;
    padding: 10px 22px;
    border-radius: var(--radius-pill);
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    border: 1px solid var(--bone-0);
    transition: background 180ms var(--ease-out), color 180ms var(--ease-out), border-color 180ms var(--ease-out);
  }
  .nav-cta:hover { background: var(--ochre-300); border-color: var(--ochre-300); color: var(--ox-900); }
  .nav-link {
    position: relative;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.003em;
    color: var(--bone-0);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    transition: color 200ms var(--ease-out);
  }

  /* Left→right underline reveal — pseudo scaleX, compositor-only. */
  .logo::after,
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 8px;
    width: 100%;
    height: 1px;
    background: var(--ochre-500);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 200ms var(--ease-out);
  }
  .logo:hover,
  .nav-link:hover { color: var(--ochre-500); }
  .logo:hover::after,
  .nav-link:hover::after,
  .nav-link:focus-visible::after { transform: scaleX(1); }

  .nav-mobile-btn {
    display: none;
    background: none;
    border: 0;
    padding: 0;
    margin: 0;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--bone-0);
  }
  .icon-close { display: none; }
  header.menu-open .icon-open { display: none; }
  header.menu-open .icon-close { display: inline-flex; }

  .nav-mobile-sheet {
    display: none;
    background: var(--ox-900);
    border-top: 1px solid var(--ox-500);
    color: var(--bone-0);
  }
  header.menu-open .nav-mobile-sheet { display: block; }
  .sheet-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 24px 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .sheet-link {
    font-family: var(--font-sans);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.018em;
    color: var(--bone-0);
    text-decoration: none;
    display: flex;
    align-items: center;
    min-height: 44px;
    transition: color 200ms var(--ease-out);
  }
  .sheet-link:hover { color: var(--ochre-500); }
  .sheet-link--cta {
    align-self: flex-start;
    margin-top: 8px;
    color: var(--ox-900);
    background: var(--bone-0);
    padding: 12px 24px;
    border-radius: var(--radius-pill);
    font-size: 18px;
  }
  .sheet-link--cta:hover { background: var(--ochre-300); color: var(--ox-900); }

  @media (max-width: 960px) {
    .nav-desktop { display: none; }
    .nav-cta { display: none; }
    .nav-mobile-btn { display: inline-flex; }
  }
  @media (min-width: 961px) {
    .nav-mobile-sheet { display: none !important; }
  }
  @media (prefers-reduced-motion: reduce) {
    .logo::after,
    .nav-link::after { transition: none; }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>("header[data-nav]");
  if (header) {
    const onScroll = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 8);
      header.classList.toggle("is-past-hero", window.scrollY > window.innerHeight * 0.6);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    const btn = header.querySelector<HTMLButtonElement>(".nav-mobile-btn");
    const setMenu = (open: boolean) => {
      header.classList.toggle("menu-open", open);
      btn?.setAttribute("aria-expanded", String(open));
      btn?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    };
    btn?.addEventListener("click", () => setMenu(!header.classList.contains("menu-open")));
    header.querySelectorAll(".nav-mobile-sheet a").forEach((a) =>
      a.addEventListener("click", () => setMenu(false)),
    );
  }
</script>
