---
import Icon from "./Icon.astro";

interface Props {
  // Retained for backwards-compat: every page still passes heroMode.
  heroMode?: "dark" | "light";
}

const navItems = [
  { label: "Work", href: "/work" },
  { label: "Services", href: "/services" },
  { label: "Process", href: "/process" },
];
---

<header data-nav>
  <div class="bar">
    <a href="/" class="logo">
      <span class="logo__mark" aria-hidden="true"></span>
      <span class="logo__wordmark">KP Solutions</span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      {navItems.map((it) => <a href={it.href} class="nav-link">{it.label}</a>)}
    </nav>

    <a href="/contact" class="nav-cta">Contact</a>

    <button class="nav-mobile-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-sheet">
      <span class="icon-open"><Icon name="menu" size={22} /></span>
      <span class="icon-close"><Icon name="x" size={22} /></span>
    </button>
  </div>

  <div class="nav-mobile-sheet" id="mobile-sheet">
    <div class="sheet-inner">
      {navItems.map((it) => <a href={it.href} class="sheet-link">{it.label}</a>)}
      <a href="/contact" class="sheet-link sheet-link--cta">Contact</a>
    </div>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 16px;
    left: 0;
    right: 0;
    z-index: 50;
    color: var(--ink-900);
    transition: top 220ms var(--ease-out);
  }
  /* On a cream hero the bar floats with no background; once scrolled, it
     becomes a dark glass pill anchored to the very top edge. */
  header.is-scrolled { top: 12px; }
  header.is-past-hero { top: 8px; }

  .bar {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    padding: 8px 16px 8px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-radius: 999px;
    border: 1px solid oklch(0% 0 0 / 0.08);
    background: oklch(100% 0 0 / 0.6);
    -webkit-backdrop-filter: blur(12px) saturate(1.1);
    backdrop-filter: blur(12px) saturate(1.1);
    transition: background 220ms var(--ease-out), color 220ms var(--ease-out),
                border-color 220ms var(--ease-out);
  }
  header.is-scrolled .bar {
    background: oklch(11% 0.010 95 / 0.78);
    border-color: oklch(100% 0 0 / 0.08);
    color: oklch(98% 0.005 95);
  }
  header.is-past-hero .bar {
    background: oklch(11% 0.010 95 / 0.88);
  }

  .logo {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 36px;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.018em;
    color: inherit;
    text-decoration: none;
    transition: color 200ms var(--ease-out);
  }
  .logo__mark {
    display: inline-block;
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: var(--lime-500);
    box-shadow: inset 0 0 0 1px oklch(40% 0.18 124 / 0.18);
  }
  .logo__wordmark { display: inline-block; }

  .nav-desktop {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 28px;
    align-items: center;
  }
  .nav-link {
    position: relative;
    font-family: var(--font-sans);
    font-size: 13.5px;
    font-weight: 500;
    letter-spacing: -0.003em;
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    opacity: 0.78;
    transition: opacity 180ms var(--ease-out), color 180ms var(--ease-out);
  }
  .nav-link:hover { opacity: 1; color: var(--lime-700); }
  header.is-scrolled .nav-link:hover { color: var(--lime-400); }

  .nav-cta {
    font-family: var(--font-sans);
    font-size: 13.5px;
    font-weight: 500;
    letter-spacing: -0.003em;
    color: var(--ink-900);
    background: var(--lime-500);
    text-decoration: none;
    padding: 8px 18px;
    border-radius: var(--radius-pill);
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    border: 1px solid var(--lime-500);
    transition: background 180ms var(--ease-out), border-color 180ms var(--ease-out);
  }
  .nav-cta:hover { background: var(--lime-400); border-color: var(--lime-400); }

  .nav-mobile-btn {
    display: none;
    background: none;
    border: 0;
    padding: 0;
    margin: 0;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: inherit;
  }
  .icon-close { display: none; }
  header.menu-open .icon-open { display: none; }
  header.menu-open .icon-close { display: inline-flex; }

  .nav-mobile-sheet {
    display: none;
    margin: 8px 16px 0;
    border-radius: 16px;
    background: oklch(11% 0.010 95 / 0.94);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    border: 1px solid oklch(100% 0 0 / 0.08);
    color: oklch(98% 0.005 95);
  }
  header.menu-open .nav-mobile-sheet { display: block; }
  .sheet-inner {
    padding: 22px 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .sheet-link {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.018em;
    color: inherit;
    text-decoration: none;
    display: flex;
    align-items: center;
    min-height: 40px;
    transition: color 200ms var(--ease-out);
  }
  .sheet-link:hover { color: var(--lime-400); }
  .sheet-link--cta {
    align-self: flex-start;
    margin-top: 4px;
    color: var(--ink-900);
    background: var(--lime-500);
    padding: 10px 22px;
    border-radius: var(--radius-pill);
    font-size: 16px;
  }
  .sheet-link--cta:hover { background: var(--lime-400); color: var(--ink-900); }

  @media (max-width: 960px) {
    .nav-desktop { display: none; }
    .nav-cta { display: none; }
    .nav-mobile-btn { display: inline-flex; }
    .bar { padding: 8px 12px 8px 16px; }
  }
  @media (min-width: 961px) {
    .nav-mobile-sheet { display: none !important; }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>("header[data-nav]");
  if (header) {
    const onScroll = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 8);
      header.classList.toggle("is-past-hero", window.scrollY > window.innerHeight * 0.6);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    const btn = header.querySelector<HTMLButtonElement>(".nav-mobile-btn");
    const setMenu = (open: boolean) => {
      header.classList.toggle("menu-open", open);
      btn?.setAttribute("aria-expanded", String(open));
      btn?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    };
    btn?.addEventListener("click", () => setMenu(!header.classList.contains("menu-open")));
    header.querySelectorAll(".nav-mobile-sheet a").forEach((a) =>
      a.addEventListener("click", () => setMenu(false)),
    );
  }
</script>
