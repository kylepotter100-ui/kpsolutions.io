---
import CategoryText from "./CategoryText.astro";

// Full-bleed category with the copy overlaid on an abstract brand field (left-aligned).
---

<section id="internal-tools" class="build-cat build-cat--bleed">
  <div class="build-cat__bleed-surface build-cat__bleed-surface--internal">
    <div class="grain-overlay" aria-hidden="true"></div>
    <div class="build-cat__bleed-scrim"></div>

    <div class="reveal build-cat__bleed-content">
      <CategoryText
        alignment="left"
        body="Admin systems, operations dashboards, purpose-built CRMs for how your team actually works. Keyboard shortcuts, bulk actions, and the screens that vendor software refuses to give you. Designed by an operator who has used the spreadsheet you're trying to replace."
        example="A renewal-quoting console that batches 3,200 quotes into one tabular view, with keyboard nudges that cut the controller's Monday from four hours to thirty minutes."
      >
        <Fragment slot="title">Internal <span class="build-cat__italic">tools</span>.</Fragment>
      </CategoryText>
    </div>
  </div>
</section>
