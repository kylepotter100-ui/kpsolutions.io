---
// Shared text block for a build category. Title is passed as a `title` slot
// (it carries an italic display span); body/example are plain strings.
interface Props {
  body: string;
  example?: string;
  eyebrow?: string;
  alignment?: "left" | "center";
}
const { body, example, eyebrow, alignment = "left" } = Astro.props;
---

<div class:list={["build-cat__text", `build-cat__text--${alignment}`]}>
  {eyebrow && <div class="build-cat__eyebrow">{eyebrow}</div>}
  <h2 class="build-cat__title"><slot name="title" /></h2>
  <p class="build-cat__body">{body}</p>
  {
    example && (
      <p class="build-cat__example">
        <span class="build-cat__example-label">Example.</span> {example}
      </p>
    )
  }
</div>
