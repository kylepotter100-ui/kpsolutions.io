---
import GrainSurface from "../GrainSurface.astro";
import PlaceholderLabel from "../PlaceholderLabel.astro";

interface Props {
  variant: "platform" | "aeo" | "integrations";
  label: string;
  position?: "bottom-left" | "bottom-right" | "top-left" | "top-right";
}
const { variant, label, position = "bottom-left" } = Astro.props;

const grain = "0 0 0 0 0.95  0 0 0 0 0.85  0 0 0 0 0.75  0 0 0 0.4 0";
const seed = variant.length * 3;
---

<div class:list={["placeholder-surface", `placeholder-surface--${variant}`]}>
  <GrainSurface
    id={`ps-grain-${variant}`}
    baseFrequency={0.95}
    seed={seed}
    matrix={grain}
    class="placeholder-surface__grain"
  />
  <div class="placeholder-surface__scrim"></div>
  <PlaceholderLabel tone="light" position={position}>{label}</PlaceholderLabel>
</div>
