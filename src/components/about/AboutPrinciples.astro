---
const principles = [
  "Operator-to-operator, never agency-to-procurement.",
  "Fixed fees. Real timelines. Code you own.",
  "One person, end to end. No handoff theatre.",
  "AI used quietly where it earns its keep, never as a sticker.",
  "We'll tell you when off-the-shelf is the right answer, even if it costs us the build.",
];
---

<section class="about-principles">
  <div class="shell">
    <h2 class="reveal about-section-title">
      How we <span class="about-italic">work</span>.
    </h2>
    <div class="reveal about-principles__grid">
      {
        principles.map((p, i) => (
          <div class:list={["about-principle", i === 4 && "about-principle--span"]}>
            <span class="about-principle__mark"></span>
            <p class="about-principle__text">{p}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
