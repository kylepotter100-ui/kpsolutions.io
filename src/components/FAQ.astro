---
// Accessible, no-JS FAQ accordion (native <details>). Answers stay in the DOM
// (collapsed only visually) so crawlers and AI engines read them, matching the
// FAQPage schema the page emits. Shared by service pages (/build, /process).
export interface FaqItem {
  q: string;
  a: string;
}
interface Props {
  items: FaqItem[];
  heading?: string;
}
const { items, heading = "Common questions." } = Astro.props;
---

<section id="faq" aria-label="Frequently asked questions" class="faq">
  <div class="shell-tight">
    <h2 class="faq__heading reveal">{heading}</h2>
    <div class="faq__list reveal">
      {
        items.map((it) => (
          <details class="faq__item">
            <summary class="faq__q">
              <span>{it.q}</span>
              <span class="faq__icon" aria-hidden="true" />
            </summary>
            <div class="faq__a">
              <p>{it.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq {
    padding: clamp(72px, 8vw, 120px) 0;
    background: var(--ink-0);
    border-top: 1px solid oklch(0% 0 0 / 0.06);
  }
  .faq__heading {
    font-size: clamp(2rem, 1.3rem + 2.4vw, 3.25rem);
    font-weight: 500;
    letter-spacing: -0.028em;
    line-height: 1.05;
    color: var(--ink-900);
    margin: 0 0 48px;
    max-width: 18ch;
  }
  .faq__list { border-top: 1px solid oklch(0% 0 0 / 0.08); }
  .faq__item { border-bottom: 1px solid oklch(0% 0 0 / 0.08); }

  .faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 26px 0;
    cursor: pointer;
    list-style: none;
    font-size: clamp(1.0625rem, 1rem + 0.4vw, 1.25rem);
    font-weight: 500;
    letter-spacing: -0.018em;
    color: var(--ink-900);
    transition: color 160ms var(--ease-out);
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q:hover { color: var(--lime-700); }

  /* plus → minus toggle */
  .faq__icon { position: relative; width: 16px; height: 16px; flex-shrink: 0; }
  .faq__icon::before,
  .faq__icon::after {
    content: "";
    position: absolute;
    background: currentColor;
    transition: transform 200ms var(--ease-out), opacity 200ms var(--ease-out);
  }
  .faq__icon::before { top: 7px; left: 0; width: 16px; height: 1.5px; }
  .faq__icon::after { left: 7px; top: 0; width: 1.5px; height: 16px; }
  .faq__item[open] .faq__icon::after { transform: scaleY(0); opacity: 0; }

  .faq__a { padding: 0 0 28px; max-width: 62ch; }
  .faq__a p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-500);
    margin: 0;
    max-width: none;
  }
</style>
